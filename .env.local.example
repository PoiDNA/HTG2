# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Bunny Stream
BUNNY_TOKEN_KEY=your-bunny-token-key
BUNNY_API_KEY=your-bunny-api-key
BUNNY_LIBRARY_ID=your-library-id

# Bunny Storage — backup zone for sesja recordings (optional, warm DR)
# All 3 vars must be set to enable backup. Leave any empty → backup disabled (graceful degradation).
#
# Architecture: cron downloads sesja MP4 from R2, uploads to this Bunny Storage zone,
# marks backup_status='ready'. NO automatic failover in token endpoint — admin manually
# recovers from Bunny panel if primary fails (warm DR, not hot replica).
#
# 10x cheaper than Bunny Stream (no transcoding to multi-bitrate HLS variants).
#
# 1. In bunny.net panel: Storage → Add Storage Zone → e.g. "htg-backup-sessions"
# 2. Copy the FTP & API Access password (zone-specific, not account-level)
# 3. Optional: choose a regional storage endpoint for lower latency
#    (e.g. "ny.storage.bunnycdn.com" — see Storage Zone settings → Replication)
BUNNY_BACKUP_STORAGE_ZONE=
BUNNY_BACKUP_STORAGE_API_KEY=
BUNNY_BACKUP_STORAGE_HOSTNAME=storage.bunnycdn.com

# WebAuthn / Passkey
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000
WEBAUTHN_CHALLENGE_SECRET=dev-secret-change-in-production

# Admin
ADMIN_EMAILS=natalia@htg.cyou
