# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Bunny Stream
BUNNY_TOKEN_KEY=your-bunny-token-key
BUNNY_API_KEY=your-bunny-api-key
BUNNY_LIBRARY_ID=your-library-id

# Bunny Storage — HTG2 recording zone (primary storage for all live session recordings)
#
# HTG2 serves audio-only recordings (sesja phase) and internal admin video (wstep/podsumowanie).
# We use Bunny Storage (raw files) instead of Bunny Stream (HLS transcoding) because:
#   - We don't stream video — only audio playback for clients
#   - Stream transcodes into multi-bitrate HLS variants → 10x storage cost
#   - Storage keeps the raw file as-is → 1x cost
#
# Upload path (cron writes): R2 → Bunny Storage zone "htg-backup-sessions"
# Playback path (token endpoint reads): client → HTG2 Pull Zone → Bunny Storage
#
# ── Setup in bunny.net panel ───────────────────────────────────────────────
# 1. Storage → Storage Zones → Add Storage Zone
#    - Name: "htg-backup-sessions" (or similar; must match BUNNY_BACKUP_STORAGE_ZONE)
#    - Region: pick closest to your users
# 2. Open the zone → FTP & API Access → copy the "Password"
#    (zone-specific API key, NOT account-level)
# 3. CDN → Pull Zones → Add Pull Zone
#    - Origin: the storage zone you created above
#    - Name: "htg-backup-sessions" → gives you https://htg-backup-sessions.b-cdn.net
# 4. Open the Pull Zone → Security → Enable Token Authentication
#    - Copy the "Authentication Key" → this goes into BUNNY_HTG2_CDN_TOKEN_KEY
#
# Write side (cron upload):
BUNNY_BACKUP_STORAGE_ZONE=htg-backup-sessions
BUNNY_BACKUP_STORAGE_API_KEY=
BUNNY_BACKUP_STORAGE_HOSTNAME=storage.bunnycdn.com

# Read side (token endpoint playback URL signing):
BUNNY_HTG2_CDN_URL=https://htg-backup-sessions.b-cdn.net
BUNNY_HTG2_CDN_TOKEN_KEY=

# WebAuthn / Passkey
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000
WEBAUTHN_CHALLENGE_SECRET=dev-secret-change-in-production

# Admin
ADMIN_EMAILS=natalia@htg.cyou
