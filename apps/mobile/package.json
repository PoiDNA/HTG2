    "expo": "~55.0.0",
    "expo-apple-authentication": "~8.0.0",
    "expo-audio": "~1.0.0",
    "expo-auth-session": "~7.0.0",
    "expo-build-properties": "~1.0.0",
    "expo-constants": "~19.0.0",
    "expo-crypto": "~15.0.0",
    "expo-dev-client": "~7.0.0",
    "expo-image": "~3.0.0",
    "expo-linking": "~8.0.0",
