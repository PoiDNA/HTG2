# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Bunny Stream
BUNNY_TOKEN_KEY=your-bunny-token-key
BUNNY_API_KEY=your-bunny-api-key
BUNNY_LIBRARY_ID=your-library-id

# Bunny Stream — backup library for sesja recordings (optional, warm DR)
# When set, all sesja recordings are duplicated to this library after primary upload.
# Token endpoint provides hot failover to backup if primary becomes unavailable.
# Leave empty to disable backup (graceful degradation, no errors).
BUNNY_BACKUP_LIBRARY_ID=

# WebAuthn / Passkey
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000
WEBAUTHN_CHALLENGE_SECRET=dev-secret-change-in-production

# Admin
ADMIN_EMAILS=natalia@htg.cyou
